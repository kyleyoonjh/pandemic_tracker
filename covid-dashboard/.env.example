REACT_APP_USE_KR_API=false
REACT_APP_DATA_GO_KR_SERVICE_KEY=PUT_YOUR_DATA_GO_KR_DECODING_KEY_HERE
REACT_APP_DATA_GO_KR_API_URL=/api/kr-covid
REACT_APP_USE_WHO_GLOBAL=true
REACT_APP_WHO_GLOBAL_CSV_URL=/csv/WHO-COVID-19-global-data.csv
REACT_APP_USE_DISEASE_FALLBACK=false
REACT_APP_ENABLE_PUTER_GROK=false
REACT_APP_PUTER_GROK_MODEL=x-ai/grok-4.20
GEMINI_API_KEY=PUT_YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_MS=30000
GEMINI_MAX_MODEL_ATTEMPTS=2
GEMINI_ENABLE_WEB_SEARCH=true
GROQ_API_KEY=PUT_YOUR_GROQ_API_KEY_HERE
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OPENAI_API_KEY=PUT_YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4o
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.openai.azure.com
AZURE_OPENAI_API_KEY=PUT_YOUR_AZURE_OPENAI_KEY_HERE
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# Assistants + file_search: 2024-05-01-preview 이상 권장
AZURE_OPENAI_API_VERSION=2024-05-01-preview
# true(기본): WHO CSV를 벡터 스토어에 올려 file_search로 참조. false: 채팅 API만 사용
AZURE_OPENAI_FILE_SEARCH=true
ALLOW_INSECURE_SSL=true
